---
import Layout from '../../layouts/Layout.astro';
import TokenEditor from '../../components/TokenEditor.astro';
---

<Layout title="Токенатор">
  <div class="page">
    <section class="page-header">
      <div>
        <h1>Токенатор</h1>
        <p>Создавайте токены из изображений прямо в браузере: загружайте, настраивайте, экспортируйте.</p>
      </div>
    </section>
    <TokenEditor />
  </div>
</Layout>

<style>
  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .page-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    box-shadow: var(--card-shadow);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(2rem, 2.4vw, 2.5rem);
    color: var(--primary);
  }

  .page-header p {
    margin: 0;
    color: var(--text);
    line-height: 1.75;
    max-width: 720px;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  p {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--text);
  }

  @media (max-width: 840px) {
    .page {
      padding: 1.2rem 0.8rem 2rem;
    }

    .page-header {
      padding: 1rem;
    }
  }
</style>
